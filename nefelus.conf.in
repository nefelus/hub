#
# Nefelus Config
#
# This file is in TOML format (https://github.com/toml-lang/toml)
#
customerName = "Nefelus"
installationId = ""
installationType = "production"
adminEmail = "admin@example.com"
timezone = "UTC"
username =  "nefelus"
ignoreInstallationIdInFilemanagerOps = false
useDynamicNFSShares = true

[database]
host = "hub.exampe.com"
port = 3306
user = "user"
password = "secret"
database = "data"
queryinterval = 5000
connectTimeout = 30000
acquireTimeout = 30000
sslkey = "/path/to/nefelus/ssl/mysql/client-key.pem"
sslcert = "/path/to/nefelus/ssl/mysql/client-cert.pem"
sslca = "/path/to/nefelus/ssl/mysql/ca.pem"

[ssl]
key = "/path/to/ssl/key"
cert = "/path/to/ssl/cert"
ca = "/path/to/ssl/ca"

[nslm]
baseURL = "https://xxx.example.com:9911/"
accessKey = "XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
secretKey = "YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY"

[aws]
ec2_max_tries = 60
ec2_timeout = 10000

[aws.ec2]
accessKeyId = "00000000000000000000000000000000"
secretAccessKey = "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
accountId = "XXXXXXXXXXXX"
region = ""
zone = ""
keyName = "worker-key"
securityGroup = "master"
#SubnetId = "subnet-00000000"

[aws.ec2.endpoint]
protocol = "http"
host = "ec2.example.com"
port = 8773
path = "services/Cloud"
signatureVersion = "v2"

[aws.s3]
accessKeyId = "WWWWWWWWWWWWWWWWWWWW"
secretAccessKey = "a0a0a0a0a0a0a0a0a0a0a0a0a0a0a0a0a0a0a0a0"
accountId = "XXXXXXXXXXXX"
bucket = "clients-bucket"
vendorBucket = "vendor-bucket"
region = ""
serverSideEncryption = false
s3ForcePathStyle = true
expiresInMinutes = 5
uploadMethod = "post"

[aws.s3.endpoint]
protocol = "https"
host = "s3.example.com"
port = 443
path = "/"
