{
  "hubType" : "development",
  "hub" : {
     "port" : 8585
   , "host" : "127.0.0.1"
   , "ssl"  : {
        "key" : ""
      , "cert" : ""
      , "ca" : ""
     }
   , "maxRunningJobsAllowed" : 5
   , "cancelHours" : 0
   , "forceCancelHours" : 0
   , "skipCycles" : 8
  }, 
  "installationId" : "",
  "ignoreInstallationIdInFilemanagerOps" : true,
  "noVNCdebug" : false,
  "adminEmail" : "kosmasgiannis@gmail.com",
  "timezone" : "Asia/Tokyo",
  "setloginuser" : false,
  "setsecgroups" : false,
  "hasAutoAssignFloatingIp" : true,
  "database" : {
     "host" : "xx.nefelus.com"
   , "port" : 3306
   , "user" : "mruser"
   , "password" : "secret"
   , "database" : "db"
   , "connectTimeout"  : 30000
   , "acquireTimeout"  : 30000
   , "queryinterval" : 15000
  },
  "nslm" : {
     "baseURL" : "http://127.0.0.1:9911/"
   , "accessKey" : "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
   , "secretKey" : "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  },
  "vncLocalOnly" : true,
  "xterm" : "NO",
  "staticUserData" : {
    "TIMEZONE" : "UTC",
    "STUNNEL" : "YES",
    "MAKESWAPFILE" : "NO",
    "LOGO_BIG.png" : "https://www.nefelus.com/nefelus.png",
    "LOGO_SMALL.png" : "https://www.nefelus.com/nefelus_small.png",
    "LOGO_NEFELUS_BIG.png" : "https://www.nefelus.com/nefelus.png",
    "LOGO_NEFELUS_SMALL.png" : "https://www.nefelus.com/nefelus_small.png"
  },
  "aws" : {
     "ec2" : {
        "region" : "us-east-1"
      , "endPoint" : {}
      , "accessKeyId" : "xxxxxxxxxxxxxxxxxxxx"
      , "secretAccessKey" : "yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy"
      , "accountId" : "999999999999"
      , "keyName" : "keypair"
      , "securityGroup" : "sec2"
     }
   , "s3" : {
        "region" : "us-east-1"
      , "serverSideEncryption" : true
      , "s3ForcePathStyle" : false
      , "endPoint" : {}
      , "accessKeyId" : "xxxxxxxxxxxxxxxxxxxx"
      , "secretAccessKey" : "yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy"
      , "accountId" : "999999999999"
      , "bucket" : "space-1-dev"
      , "vendorBucket" : "vendor-tools-dev"
     }
   , "dnsPostprocess" : "route53"
   , "values_for_dnsPostprocess" : "none,route53,dnsresolve,dnstransform,dnsmap"
   , "dnsresolve" : {
        "domainName" : "nefelus.com"
     }
   , "dnsmap" : {
        "map" : {"100.100.100.100" : "www.nefelus.com", "200.200.200.200" : "web.nefelus.com"}
     }
   , "dnstransform" : {
        "matches" : [ "/[.]/g", "/^/", "/$/" ]
      , "values"  : [ "-", "w-", "." ]
      , "domainName" : "nefelus.com"
     }
   , "route53" : {
        "hostedZone" : "zzzzzzzzzzzzz"
      , "providerDomainName" : ".amazonaws.com"
      , "domainName" : "-m.nefelus.com"
     }
   , "ec2_max_tries" : 60
   , "ec2_timeout" : 10000
  },
  "nefelus" : {
     "username" : "nefelus"
   , "masterDebug" : true
   , "masterScripts" : false
   , "heartbeatInterval" : 60000
   , "x11IdleTimeout" : 0
   , "homeBlacklistPatterns" : [ "!/home/nefelus/.Xauthority"
                               , "!/home/nefelus/.bashrc*"
                               , "!/home/nefelus/.twmrc"
                               , "!/home/nefelus/.profile"
                               , "!/home/nefelus/.cshrc"
                               , "!/home/nefelus/.tcshrc"
                               , "!/home/nefelus/.vnc/*"
                               , "!/home/nefelus/.ssh/*"
                               , "!/home/nefelus/tool/**"
                               , "!/home/nefelus/**/*.lock"
                               , "!/home/nefelus/.npm/*"
                               , "!/home/nefelus/.jx/*"
                               , "!/home/nefelus/.node-gyp/*"
                               , "!/home/nefelus/.fontconfig/*"
                               , "!/mnt/ephemeral/nefelus/.Xauthority"
                               , "!/mnt/ephemeral/nefelus/.bashrc*"
                               , "!/mnt/ephemeral/nefelus/.twmrc"
                               , "!/mnt/ephemeral/nefelus/.profile"
                               , "!/mnt/ephemeral/nefelus/.cshrc"
                               , "!/mnt/ephemeral/nefelus/.tcshrc"
                               , "!/mnt/ephemeral/nefelus/.vnc/*"
                               , "!/mnt/ephemeral/nefelus/.ssh/*"
                               , "!/mnt/ephemeral/nefelus/tool/**"
                               , "!/mnt/ephemeral/nefelus/**/*.lock"
                               , "!/mnt/ephemeral/nefelus/.npm/*"
                               , "!/mnt/ephemeral/nefelus/.jx/*"
                               , "!/mnt/ephemeral/nefelus/.node-gyp/*"
                               , "!/mnt/ephemeral/nefelus/.fontconfig/*"
                               , "!/mnt/nefelus/.Xauthority"
                               , "!/mnt/nefelus/.bashrc*"
                               , "!/mnt/nefelus/.twmrc"
                               , "!/mnt/nefelus/.profile"
                               , "!/mnt/nefelus/.cshrc"
                               , "!/mnt/nefelus/.tcshrc"
                               , "!/mnt/nefelus/.vnc/*"
                               , "!/mnt/nefelus/.ssh/*"
                               , "!/mnt/nefelus/tool/**"
                               , "!/mnt/nefelus/.npm/*"
                               , "!/mnt/nefelus/.jx/*"
                               , "!/mnt/nefelus/.node-gyp/*"
                               , "!/mnt/nefelus/**/*.lock"
                               , "!/mnt/nefelus/.fontconfig/*"
                               ]
   , "logURL" : { "port" : "8998", "protocol" : "http"}
   , "vncURL" : { "port" : "8997", "protocol" : "http"}
   , "cmdURL" : { "port" : "8996", "protocol" : "http"}
  },
  "emailTemplates" : [
     {
       "name" : "session-status",
       "source" : "session-status.html",
       "subject" : "Status report for session {{ID}}",
       "context" : {
                     "firstname" : "",
                     "ID" : "",
                     "toolname" : "",
                     "blockname" : "",
                     "projectname" : "",
                     "started" : "",
                     "completed" : "",
                     "status" : ""
       }
     }
  ]
}
