{
    "env": {
        "node": true,
        "amd": true
    },
    "extends": "eslint:recommended",
    "rules": {
        "no-console":0,
        "no-unused-vars": ["error", { "vars": "all", "args": "none" }],
        "linebreak-style": ["error", "unix"],
        "quotes": ["error", "single"],
        "semi": ["error", "always"],
        "curly": ["error", "all"],
        "no-path-concat": ["error"],
        "callback-return": ["off"],
        "handle-callback-err": ["off"]
    }
}
