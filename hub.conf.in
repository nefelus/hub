#
# Nefelus HUB config
#
# This file is in TOML format (https://github.com/toml-lang/toml)

# hubType : default value is "production" and is passed to VM via userdata.
# If set to "ami" then the machine is supposed to be used for VM image creation.
hubType = "production"

# host : the hostname or IP address where the service will listen for incomming connections. Defaults to localhost
host = "hub.example.com"
# port : the port where the service will listen for incomming connections. Defaults to 8585
port = 8585

# filemanager: the endpoint of nefelus-s3 service
filemanager = "https://hub.example.com:8888"

# hasAutoAssignFloatingIp : flag if the cloud stack assigns an IP address to the launching VM.
hasAutoAssignFloatingIp : false

# logHeartBeats : flag if the incomming heartbeat messages from workers are logged or not
logHeartBeats : true

skipCycles = 8
cancelHours = 0
forceCancelHours = 0

# setloginuser : By default the user running the tools in a worker VM is 'nefelus'.
# By setting setloginuser to true, the user running the tools is set to the username launching the tool from the Web FrontEnd.
setloginuser = true
setsecgroups = false
# vncLocalOnly : Control if for GUI interactive tools access to the machine is allowed by third party VNC clients or
# if access is allowed only via noVNC web client installed locally.
vncLocalOnly = false

# masterScripts: path to filename or false.
# It is used for debuging VM startup scripts
masterScripts = false

[aws]
dnsPostprocess = "dnstransform"

[aws.dnstransform]
matches =  [ "/[.]/g", "/^/", "/$/" ]
values = [ "-", "worker-", "." ]
domainName = "cdc-lab.com"

[aws.route53]

# database config is normally set in nefelus.conf
# values here overide default ones.
[database]
#queryinterval: it is used to set the polling intervals to check if there are pending jobs
queryinterval = 15000

# Static user data are passed verbatim to the VM
[staticUserData]
#timezone: a valid timezone for example: "Asia/Tokyo", "Europe/Athens", UTC etc
TIMEZONE = "UTC"
# makeswapfile: controls if the VM on startup will create a swap file, usefull for VMs with small RAM
MAKESWAPFILE = "NO"
#stunnel: controls if the stunnel will be the SSL endpoint instead of the local daemons
STUNNEL = "YES"
# Logos used for branding the noVNC desktop
"LOGO_BIG.png" = "https://www.example.com/nefelus.png"
"LOGO_SMALL.png" = "https://www.example.com/nefelus_small.png"
"LOGO_NEFELUS_BIG.png" = "https://www.example.com/nefelus.png"
"LOGO_NEFELUS_SMALL.png" = "https://www.example.com/nefelus_small.png"

[vm]
username = "nefelus"
masterDebug = true
heartbeatInterval = 60000
x11IdleTimeout = 0
# set the size of VM's root volume (applicable only at Amazon, OpenStack does not support it yet)
# if set to zero the image snapshot size is used.
rootVolumeSize = 0
homeBlacklistPatterns = [ "!/home/nefelus/.Xauthority"
                        , "!/home/nefelus/.bashrc*"
                        , "!/home/nefelus/.twmrc"
                        , "!/home/nefelus/.profile"
                        , "!/home/nefelus/.cshrc"
                        , "!/home/nefelus/.tcshrc"
                        , "!/home/nefelus/.vnc/*"
                        , "!/home/nefelus/.ssh/*"
                        , "!/home/nefelus/tool/**"
                        , "!/home/nefelus/**/*.lock"
                        , "!/home/nefelus/.npm/*"
                        , "!/home/nefelus/.jx/*"
                        , "!/home/nefelus/.node-gyp/*"
                        , "!/home/nefelus/.fontconfig/*"
                        , "!/mnt/ephemeral/nefelus/.Xauthority"
                        , "!/mnt/ephemeral/nefelus/.bashrc*"
                        , "!/mnt/ephemeral/nefelus/.twmrc"
                        , "!/mnt/ephemeral/nefelus/.profile"
                        , "!/mnt/ephemeral/nefelus/.cshrc"
                        , "!/mnt/ephemeral/nefelus/.tcshrc"
                        , "!/mnt/ephemeral/nefelus/.vnc/*"
                        , "!/mnt/ephemeral/nefelus/.ssh/*"
                        , "!/mnt/ephemeral/nefelus/tool/**"
                        , "!/mnt/ephemeral/nefelus/**/*.lock"
                        , "!/mnt/ephemeral/nefelus/.npm/*"
                        , "!/mnt/ephemeral/nefelus/.jx/*"
                        , "!/mnt/ephemeral/nefelus/.node-gyp/*"
                        , "!/mnt/ephemeral/nefelus/.fontconfig/*"
                        , "!/mnt/nefelus/.Xauthority"
                        , "!/mnt/nefelus/.bashrc*"
                        , "!/mnt/nefelus/.twmrc"
                        , "!/mnt/nefelus/.profile"
                        , "!/mnt/nefelus/.cshrc"
                        , "!/mnt/nefelus/.tcshrc"
                        , "!/mnt/nefelus/.vnc/*"
                        , "!/mnt/nefelus/.ssh/*"
                        , "!/mnt/nefelus/tool/**"
                        , "!/mnt/nefelus/.npm/*"
                        , "!/mnt/nefelus/.jx/*"
                        , "!/mnt/nefelus/.node-gyp/*"
                        , "!/mnt/nefelus/**/*.lock"
                        , "!/mnt/nefelus/.fontconfig/*"
                        ]

# Definitions for VM Dashboard and log viewer access
[vm.logURL]
port = "8998"
protocol = "https"

# Definitions for VNC console access
[vm.vncURL]
port = "8997"
protocol = "https"
debug = false

# Definitions for prompt console access
[vm.cmdURL]
port = "8996"
protocol = "https"

[vm.shares]
cifsMountParams = "gid=1001,uid=1001,vers=3.0"
nfsMountParams = ""

[[emailTemplates]]
name="session-status"
source = "session-status.html"
subject = "Status report for session {{ID}}"
[emailTemplates.context]
firstname = ""
ID = ""
toolname = ""
blockname = ""
projectname = ""
started = ""
completed = ""
status = ""
